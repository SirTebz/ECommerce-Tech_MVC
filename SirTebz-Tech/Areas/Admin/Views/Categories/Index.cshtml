@model IEnumerable<SirTebz_Tech.Models.Entities.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="admin-page-title mb-0">Categories</h1>
    <a asp-action="Create" class="btn btn-admin-action"><i class="bi bi-plus-circle me-2"></i>Add Category</a>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table admin-table">
            <thead><tr><th>Name</th><th>Description</th><th>Icon</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td class="fw-semibold">@cat.Name</td>
                        <td class="text-muted small">@cat.Description</td>
                        <td><i class="@cat.IconClass"></i> <code class="small">@cat.IconClass</code></td>
                        <td><span class="badge @(cat.IsActive ? "bg-success" : "bg-secondary")">@(cat.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-admin-xs btn-edit"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete @cat.Name?')">
                                <input type="hidden" name="id" value="@cat.Id" />
                                <button type="submit" class="btn btn-admin-xs btn-delete"><i class="bi bi-trash3"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>