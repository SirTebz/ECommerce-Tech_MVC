@model List<SirTebz_Tech.Models.ViewModels.ProductCardViewModel>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h1 class="admin-page-title mb-0">Products</h1>
        <p class="admin-page-subtitle mb-0">Manage your product catalog (@Model.Count total)</p>
    </div>
    <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="btn btn-admin-action">
        <i class="bi bi-plus-circle me-2"></i>Add New Product
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-header d-flex gap-2">
        <input type="text" id="productSearch" class="form-control admin-search" placeholder="Search products..." oninput="filterProducts(this.value)" />
    </div>
    <div class="table-responsive">
        <table class="table admin-table" id="productsTable">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Brand</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Featured</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr class="product-row">
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@(p.ImageUrl ?? "/images/placeholder.jpg")" width="44" height="44"
                                     class="rounded product-thumb"
                                     onerror="this.src='/images/placeholder.jpg'" />
                                <div>
                                    <div class="fw-semibold">@p.Name</div>
                                    @if (p.IsOnSale)
                                    {
                                        <span class="badge bg-danger badge-xs">SALE -@p.DiscountPercent%</span>
                                    }
                                </div>
                            </div>
                        </td>
                        <td><span class="badge-category">@p.CategoryName</span></td>
                        <td>@p.BrandName</td>
                        <td>
                            <div>R @p.Price.ToString("N2")</div>
                            @if (p.IsOnSale && p.OriginalPrice.HasValue)
                            {
                                <div class="text-muted text-decoration-line-through small">R @p.OriginalPrice.Value.ToString("N2")</div>
                            }
                        </td>
                        <td>
                            <span class="badge @(p.Stock > 5 ? "bg-success" : p.Stock > 0 ? "bg-warning text-dark" : "bg-danger")">
                                @p.Stock units
                            </span>
                        </td>
                        <td>
                            @if (p.IsFeatured)
                            {
                                <i class="bi bi-star-fill text-warning"></i>
                            }
                            else
                            {
                                <i class="bi bi-star text-muted"></i>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-area="Admin" asp-controller="Products" asp-action="Edit"
                                       asp-route-id="@p.Id" class="btn btn-admin-xs btn-edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id"
                                       asp-area="" class="btn btn-admin-xs btn-view" target="_blank">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-area="Admin" asp-controller="Products" asp-action="Delete"
                                      method="post" onsubmit="return confirm('Delete @p.Name?')">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="btn btn-admin-xs btn-delete">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function filterProducts(val) {
            const rows = document.querySelectorAll('#productsTable .product-row');
            const v = val.toLowerCase();
            rows.forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(v) ? '' : 'none';
            });
        }
    </script>
}