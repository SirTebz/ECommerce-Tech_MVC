@model SirTebz_Tech.Models.ViewModels.ProductCreateEditViewModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="admin-page-title mb-0">Edit Product</h1>
        <p class="admin-page-subtitle mb-0">@Model.Name</p>
    </div>
    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-admin-back">
        <i class="bi bi-arrow-left me-1"></i>Back to Products
    </a>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @await Html.PartialAsync("_ProductForm", Model)
</form>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}