@model SirTebz_Tech.Models.ViewModels.ProductCreateEditViewModel

<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
<input type="hidden" asp-for="Id" />
<input type="hidden" asp-for="ImageUrl" />

<div class="row g-4">
    <div class="col-lg-8">
        <!-- BASIC INFO -->
        <div class="admin-card mb-4">
            <div class="admin-card-header"><h6 class="admin-card-title mb-0">Product Information</h6></div>
            <div class="admin-card-body">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label admin-label">Product Name *</label>
                    <input asp-for="Name" class="form-control admin-input" placeholder="e.g. Dell XPS 15 (2024)" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label admin-label">Description *</label>
                    <textarea asp-for="Description" class="form-control admin-input" rows="5"
                              placeholder="Detailed product description..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label admin-label">Category *</label>
                        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select admin-input">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BrandId" class="form-label admin-label">Brand *</label>
                        <select asp-for="BrandId" asp-items="Model.Brands" class="form-select admin-input">
                            <option value="">-- Select Brand --</option>
                        </select>
                        <span asp-validation-for="BrandId" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- PRICING & STOCK -->
        <div class="admin-card mb-4">
            <div class="admin-card-header"><h6 class="admin-card-title mb-0">Pricing & Inventory</h6></div>
            <div class="admin-card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label admin-label">Selling Price (R) *</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control admin-input" placeholder="0.00" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="OriginalPrice" class="form-label admin-label">Original Price (R)</label>
                        <input asp-for="OriginalPrice" type="number" step="0.01" class="form-control admin-input" placeholder="Leave empty if no sale" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Stock" class="form-label admin-label">Stock Quantity *</label>
                        <input asp-for="Stock" type="number" class="form-control admin-input" placeholder="0" />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>
                </div>
                <div class="mt-3 d-flex gap-4">
                    <div class="form-check">
                        <input asp-for="IsFeatured" class="form-check-input" />
                        <label asp-for="IsFeatured" class="form-check-label">Featured Product</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Active (visible)</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- SPECIFICATIONS -->
        <div class="admin-card">
            <div class="admin-card-header d-flex justify-content-between align-items-center">
                <h6 class="admin-card-title mb-0">Specifications</h6>
                <button type="button" class="btn btn-admin-sm" onclick="addSpec()">
                    <i class="bi bi-plus me-1"></i>Add Spec
                </button>
            </div>
            <div class="admin-card-body">
                <div id="specsContainer">
                    @for (int i = 0; i < Model.Specifications.Count; i++)
                    {
                        <div class="spec-row d-flex gap-2 mb-2 align-items-center" id="specRow_@i">
                            <input type="text" name="Specifications[@i].Key" value="@Model.Specifications[i].Key"
                                   class="form-control admin-input" placeholder="e.g. RAM" />
                            <input type="text" name="Specifications[@i].Value" value="@Model.Specifications[i].Value"
                                   class="form-control admin-input" placeholder="e.g. 16GB DDR5" />
                            <button type="button" class="btn btn-admin-xs btn-delete flex-shrink-0"
                                    onclick="this.closest('.spec-row').remove()">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    }
                </div>
                <p class="text-muted small mt-2">Add specifications like RAM, CPU, Storage, GPU, etc.</p>
            </div>
        </div>
    </div>

    <!-- SIDEBAR: IMAGE -->
    <div class="col-lg-4">
        <div class="admin-card mb-4">
            <div class="admin-card-header"><h6 class="admin-card-title mb-0">Product Image</h6></div>
            <div class="admin-card-body text-center">
                <div class="image-preview-wrap mb-3" id="imagePreview">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="img-fluid rounded admin-img-preview"
                             onerror="this.src='/images/placeholder.jpg'" id="previewImg" />
                    }
                    else
                    {
                        <div class="no-image-placeholder" id="noImgPlaceholder">
                            <i class="bi bi-image"></i>
                            <div>No image</div>
                        </div>
                        <img id="previewImg" class="img-fluid rounded admin-img-preview" style="display:none" />
                    }
                </div>
                <input asp-for="ImageFile" type="file" class="form-control admin-input" accept="image/*"
                       onchange="previewImage(this)" />
                <div class="form-text">JPG, PNG. Max 5MB.</div>
                <div class="mt-2">
                    <label class="admin-label small">Or paste image URL:</label>
                    <input asp-for="ImageUrl" class="form-control admin-input" placeholder="https://..." />
                </div>
            </div>
        </div>

        <div class="admin-card">
            <div class="admin-card-body">
                <button type="submit" class="btn btn-admin-action w-100 mb-2">
                    <i class="bi bi-check-circle me-2"></i>Save Product
                </button>
                <a asp-area="Admin" asp-controller="Products" asp-action="Index"
                   class="btn btn-admin-back w-100">Cancel</a>
            </div>
        </div>
    </div>
</div>

<script>
    let specIndex = @Model.Specifications.Count;
    function addSpec() {
        const container = document.getElementById('specsContainer');
        const row = document.createElement('div');
        row.className = 'spec-row d-flex gap-2 mb-2 align-items-center';
        row.id = 'specRow_' + specIndex;
        row.innerHTML = `
            <input type="text" name="Specifications[${specIndex}].Key" class="form-control admin-input" placeholder="e.g. RAM" />
            <input type="text" name="Specifications[${specIndex}].Value" class="form-control admin-input" placeholder="e.g. 16GB DDR5" />
            <button type="button" class="btn btn-admin-xs btn-delete flex-shrink-0" onclick="this.closest('.spec-row').remove()">
                <i class="bi bi-trash3"></i>
            </button>`;
        container.appendChild(row);
        specIndex++;
    }
    function previewImage(input) {
        const file = input.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = e => {
            const img = document.getElementById('previewImg');
            const ph = document.getElementById('noImgPlaceholder');
            img.src = e.target.result;
            img.style.display = 'block';
            if (ph) ph.style.display = 'none';
        };
        reader.readAsDataURL(file);
    }
</script>