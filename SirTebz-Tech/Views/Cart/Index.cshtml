@model SirTebz_Tech.Models.ViewModels.CartViewModel
@{
    ViewData["Title"] = "My Cart";
}

<div class="cart-page py-4">
    <div class="container-xl">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb sttech-breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active">My Cart</li>
            </ol>
        </nav>

        <h1 class="page-title mb-4">
            <i class="bi bi-bag me-2"></i>Shopping Cart
            @if (Model.ItemCount > 0)
            {
                <span class="cart-count-badge ms-2">@Model.ItemCount items</span>
            }
        </h1>

        @if (!Model.Items.Any())
        {
            <div class="empty-cart text-center py-5">
                <i class="bi bi-bag empty-icon"></i>
                <h3 class="mt-3">Your cart is empty</h3>
                <p class="text-muted mb-4">Looks like you haven't added anything yet.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-hero-primary">
                    <i class="bi bi-grid me-2"></i>Start Shopping
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                <!-- CART ITEMS -->
                <div class="col-lg-8">
                    <div class="cart-items-wrap">
                        @foreach (var item in Model.Items)
                        {
                            <div class="cart-item" id="cartItem_@item.CartItemId">
                                <div class="cart-item-img">
                                    <img src="@(item.ImageUrl ?? "/images/placeholder.jpg")"
                                         alt="@item.ProductName"
                                         onerror="this.src='/images/placeholder.jpg'" />
                                </div>
                                <div class="cart-item-info flex-grow-1">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId"
                                       class="cart-item-name">@item.ProductName</a>
                                    <div class="cart-item-price">R @item.Price.ToString("N2") each</div>
                                </div>
                                <div class="cart-item-qty">
                                    <div class="qty-control">
                                        <button class="btn btn-qty" onclick="updateCartQty(@item.CartItemId, @(item.Quantity - 1))">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <span class="qty-display" id="qty_@item.CartItemId">@item.Quantity</span>
                                        <button class="btn btn-qty" onclick="updateCartQty(@item.CartItemId, @(item.Quantity + 1))" @(item.Quantity >= item.MaxStock ? "disabled" : "")>
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="cart-item-subtotal">
                                    <span id="subtotal_@item.CartItemId">R @item.Subtotal.ToString("N2")</span>
                                </div>
                                <button class="btn btn-remove-item" onclick="removeCartItem(@item.CartItemId)" title="Remove">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <a asp-controller="Products" asp-action="Index" class="btn btn-continue-shopping">
                            <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                        </a>
                        <button class="btn btn-clear-cart" onclick="if(confirm('Clear cart?')) location.href='/Cart/Checkout'">
                            <i class="bi bi-trash me-1"></i>Clear Cart
                        </button>
                    </div>
                </div>

                <!-- ORDER SUMMARY -->
                <div class="col-lg-4">
                    <div class="order-summary">
                        <h5 class="summary-title">Order Summary</h5>
                        <div class="summary-row"><span>Subtotal</span><span id="cartTotalDisplay">R @Model.Total.ToString("N2")</span></div>
                        <div class="summary-row"><span>Delivery</span><span class="text-success">@(Model.Total >= 2000 ? "FREE" : "R 150.00")</span></div>
                        <div class="summary-row summary-row-total">
                            <span>Total</span>
                            <span>R @((Model.Total >= 2000 ? Model.Total : Model.Total + 150).ToString("N2"))</span>
                        </div>

                        <form asp-action="Checkout" method="post" class="mt-3">
                            <button type="submit" class="btn btn-checkout w-100">
                                <i class="bi bi-credit-card me-2"></i>Proceed to Checkout
                            </button>
                        </form>

                        <div class="summary-features mt-3">
                            <div><i class="bi bi-shield-check me-2 text-success"></i>Secure Checkout</div>
                            <div><i class="bi bi-truck me-2 text-success"></i>Free delivery over R2,000</div>
                            <div><i class="bi bi-arrow-counterclockwise me-2 text-success"></i>30-day returns</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function updateCartQty(cartItemId, qty) {
            if (qty < 0) return;
            fetch('/Cart/UpdateQuantity', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                body: `cartItemId=${cartItemId}&quantity=${qty}&__RequestVerificationToken=${getAntiForgeryToken()}`
            }).then(r => r.json()).then(data => {
                if (data.success) {
                    if (qty === 0) {
                        document.getElementById('cartItem_' + cartItemId)?.remove();
                    } else {
                        document.getElementById('qty_' + cartItemId).textContent = qty;
                    }
                    document.getElementById('cartTotalDisplay').textContent = 'R ' + parseFloat(data.total.replace(/[^0-9.]/g,'')).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
                    updateCartBadge(data.itemCount);
                }
            });
        }
        function removeCartItem(cartItemId) {
            fetch('/Cart/Remove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                body: `cartItemId=${cartItemId}&__RequestVerificationToken=${getAntiForgeryToken()}`
            }).then(r => r.json()).then(data => {
                if (data.success) {
                    document.getElementById('cartItem_' + cartItemId)?.remove();
                    showToast('info', 'Item removed from cart');
                }
            });
        }
    </script>
}