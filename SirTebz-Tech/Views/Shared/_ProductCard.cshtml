@model SirTebz_Tech.Models.ViewModels.ProductCardViewModel

<div class="product-card h-100" data-product-id="@Model.Id">
    <!-- BADGE -->
    <div class="product-badges">
        @if (Model.IsOnSale)
        {
            <span class="badge-sale">-@Model.DiscountPercent%</span>
        }
        @if (Model.IsFeatured)
        {
            <span class="badge-featured">Featured</span>
        }
        @if (Model.Stock <= 3 && Model.Stock > 0)
        {
            <span class="badge-low-stock">Only @Model.Stock left</span>
        }
        @if (Model.Stock == 0)
        {
            <span class="badge-out-stock">Out of Stock</span>
        }
    </div>

    <!-- IMAGE -->
    <a asp-controller="Products" asp-action="Details" asp-route-id="@Model.Id" class="product-img-link">
        <div class="product-img-wrap">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" class="product-img"
                     onerror="this.src='/images/placeholder.jpg'" loading="lazy" />
            }
            else
            {
                <div class="product-img-placeholder">
                    <i class="bi bi-laptop"></i>
                </div>
            }
        </div>
    </a>

    <!-- BODY -->
    <div class="product-card-body">
        <div class="product-meta">
            <span class="product-brand">@Model.BrandName</span>
            <span class="product-category">@Model.CategoryName</span>
        </div>

        <a asp-controller="Products" asp-action="Details" asp-route-id="@Model.Id" class="product-name-link">
            <h6 class="product-name">@Model.Name</h6>
        </a>

        <div class="product-price-row">
            <span class="product-price">R @Model.Price.ToString("N2")</span>
            @if (Model.IsOnSale && Model.OriginalPrice.HasValue)
            {
                <span class="product-original-price">R @Model.OriginalPrice.Value.ToString("N2")</span>
            }
        </div>

        <!-- ACTIONS -->
        <div class="product-actions mt-2">
            @if (Model.Stock > 0)
            {
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="btn btn-add-cart w-100 mb-2"
                            onclick="addToCart(@Model.Id, this)"
                            data-product-id="@Model.Id">
                        <i class="bi bi-bag-plus me-1"></i>Add to Cart
                    </button>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-add-cart w-100 mb-2">
                        <i class="bi bi-bag-plus me-1"></i>Add to Cart
                    </a>
                }
            }
            else
            {
                <button class="btn btn-out-of-stock w-100 mb-2" disabled>
                    <i class="bi bi-x-circle me-1"></i>Out of Stock
                </button>
            }

            <div class="d-flex gap-2">
                <a asp-controller="Products" asp-action="Details" asp-route-id="@Model.Id"
                       class="btn btn-view-detail flex-grow-1">
                    <i class="bi bi-eye me-1"></i>View
                </a>
                <button class="btn btn-compare-add" onclick="addToCompare(@Model.Id, '@Model.Name.Replace("'", "\\'")')"
                        title="Compare" data-product-id="@Model.Id">
                    <i class="bi bi-bar-chart-steps"></i>
                </button>
            </div>
        </div>
    </div>
</div>