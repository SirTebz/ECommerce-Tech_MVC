<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sir Tebz.Tech</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="sttech-body">

    <!-- TOP BAR -->
    <div class="topbar d-none d-md-block">
        <div class="container-xl d-flex justify-content-between align-items-center">
            <span><i class="bi bi-geo-alt-fill me-1"></i>Pretoria, South Africa &nbsp;|&nbsp; <i class="bi bi-envelope-fill me-1"></i>support@sirtebz.tech</span>
            <span><i class="bi bi-truck me-1"></i>Free delivery on orders over R2,000 &nbsp;|&nbsp; <i class="bi bi-shield-check-fill me-1"></i>2-Year Warranty</span>
        </div>
    </div>

    <!-- MAIN NAVBAR -->
    <nav class="navbar navbar-expand-lg sttech-navbar sticky-top">
        <div class="container-xl">

            <!-- LOGO -->
            <a class="navbar-brand sttech-logo" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="Sir Tebz.Tech" height="46" class="logo-img" onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" />
                <span class="logo-text" style="display:none"><span class="logo-sir">Sir</span><span class="logo-tebz"> Tebz</span><span class="logo-dot">.</span><span class="logo-tech">Tech</span></span>
            </a>

            <!-- SEARCH (desktop) -->
            <form class="sttech-searchbar d-none d-lg-flex" asp-controller="Products" asp-action="Index" method="get">
                <input class="form-control search-input" type="search" name="searchTerm"
                       placeholder="Search laptops, GPUs, accessories..."
                       value="@ViewData["SearchTerm"]" autocomplete="off" />
                <button class="btn search-btn" type="submit"><i class="bi bi-search"></i></button>
            </form>

            <!-- RIGHT ICONS -->
            <div class="navbar-right-icons d-flex align-items-center gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown">
                        <button class="nav-icon-btn dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i>
                            <span class="d-none d-md-inline">@User.Identity.Name?.Split('@')[0]</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end sttech-dropdown">
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Admin Panel</a></li>
                            }
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="nav-icon-btn">
                        <i class="bi bi-person-circle"></i>
                        <span class="d-none d-md-inline">Login</span>
                    </a>
                }

                <!-- COMPARE -->
                <button class="nav-icon-btn position-relative" id="compareNavBtn" onclick="window.location.href='/Compare'" title="Compare Products">
                    <i class="bi bi-bar-chart-steps"></i>
                    <span class="badge-count" id="compareCount" style="display:none">0</span>
                </button>

                <!-- CART -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Cart" asp-action="Index" class="nav-icon-btn position-relative" id="cartNavBtn">
                        <i class="bi bi-bag"></i>
                        <span class="badge-count" id="cartCount">0</span>
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="nav-icon-btn position-relative">
                        <i class="bi bi-bag"></i>
                    </a>
                }

                <!-- MOBILE TOGGLE -->
                <button class="navbar-toggler nav-icon-btn" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <i class="bi bi-list"></i>
                </button>
            </div>
        </div>

        <!-- CATEGORY NAV ROW -->
        <div class="container-xl mt-1 d-none d-lg-block">
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav cat-nav gap-1">
                    <li class="nav-item">
                        <a class="cat-nav-link" asp-controller="Products" asp-action="Index"><i class="bi bi-grid-fill me-1"></i>All Products</a>
                    </li>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories as IEnumerable<SirTebz_Tech.Models.Entities.Category> ?? Enumerable.Empty<SirTebz_Tech.Models.Entities.Category>())
                        {
                            <li class="nav-item">
                                <a class="cat-nav-link" asp-controller="Products" asp-action="Index" asp-route-categoryId="@cat.Id">
                                    @if (!string.IsNullOrEmpty(cat.IconClass))
                                    {
                                        <i class="@cat.IconClass me-1"></i>
                                    }
                                    @cat.Name
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>

        <!-- MOBILE SEARCH + NAV -->
        <div class="container-xl d-lg-none mt-2">
            <div class="collapse navbar-collapse" id="navbarMain">
                <form class="d-flex mb-2" asp-controller="Products" asp-action="Index" method="get">
                    <input class="form-control search-input me-2" type="search" name="searchTerm" placeholder="Search products..." />
                    <button class="btn search-btn" type="submit"><i class="bi bi-search"></i></button>
                </form>
                <ul class="navbar-nav flex-column">
                    <li class="nav-item"><a class="nav-link cat-nav-link-mobile" asp-controller="Products" asp-action="Index">All Products</a></li>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories as IEnumerable<SirTebz_Tech.Models.Entities.Category> ?? Enumerable.Empty<SirTebz_Tech.Models.Entities.Category>())
                        {
                            <li class="nav-item">
                                <a class="nav-link cat-nav-link-mobile" asp-controller="Products" asp-action="Index" asp-route-categoryId="@cat.Id">@cat.Name</a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- TOAST CONTAINER -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer" style="z-index:9999"></div>

    <!-- ALERTS -->
    @if (TempData["Success"] != null)
    {
        <div class="alert-banner alert-banner-success">
            <div class="container-xl d-flex align-items-center justify-content-between">
                <span><i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]</span>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-banner alert-banner-error">
            <div class="container-xl d-flex align-items-center justify-content-between">
                <span><i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]</span>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <!-- MAIN CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- COMPARE TRAY -->
    <div class="compare-tray" id="compareTray" style="display:none">
        <div class="container-xl d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-3">
                <span class="compare-tray-title"><i class="bi bi-bar-chart-steps me-2"></i>Compare Products</span>
                <div class="d-flex gap-2" id="compareTrayItems"></div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-compare-go" id="compareTrayGoBtn">Compare Now</button>
                <button class="btn btn-compare-clear" onclick="clearCompare()">Clear All</button>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="sttech-footer mt-auto">
        <div class="container-xl">
            <div class="row g-4 py-5">
                <div class="col-lg-4">
                    <div class="footer-brand mb-3">
                        <span class="logo-sir">Sir</span><span class="logo-tebz"> Tebz</span><span class="logo-dot">.</span><span class="logo-tech">Tech</span>
                    </div>
                    <p class="footer-desc">Your premier destination for cutting-edge technology. We bring you the best laptops, PCs, GPUs, and accessories at competitive prices.</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="social-link"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-link"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="social-link"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-link"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-2">
                    <h6 class="footer-heading">Shop</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Products" asp-action="Index">All Products</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="1">Laptops</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="3">Graphics Cards</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="4">Monitors</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="5">Accessories</a></li>
                    </ul>
                </div>
                <div class="col-sm-6 col-lg-2">
                    <h6 class="footer-heading">Account</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                        <li><a asp-controller="Account" asp-action="Register">Register</a></li>
                        <li><a asp-controller="Cart" asp-action="Index">My Cart</a></li>
                        <li><a asp-controller="Account" asp-action="Profile">My Profile</a></li>
                    </ul>
                </div>
                <div class="col-sm-6 col-lg-4">
                    <h6 class="footer-heading">Contact</h6>
                    <ul class="footer-contact">
                        <li><i class="bi bi-geo-alt-fill"></i> Pretoria, Gauteng, South Africa</li>
                        <li><i class="bi bi-envelope-fill"></i> support@sirtebz.tech</li>
                        <li><i class="bi bi-telephone-fill"></i> +27 12 000 0000</li>
                        <li><i class="bi bi-clock-fill"></i> Mon–Fri: 08:00–17:00</li>
                    </ul>
                </div>
            </div>
            <hr class="footer-divider" />
            <div class="footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-center py-3 gap-2">
                <span>&copy; @DateTime.Now.Year Sir Tebz.Tech. All rights reserved.</span>
                <div class="d-flex gap-2 payment-icons">
                    <span class="pay-icon">VISA</span>
                    <span class="pay-icon">MC</span>
                    <span class="pay-icon">PayFast</span>
                    <span class="pay-icon">EFT</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/compare.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>