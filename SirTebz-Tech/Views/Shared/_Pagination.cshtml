@model SirTebz_Tech.Models.ViewModels.PaginationViewModel
@{
    var routeValues = ViewContext.RouteData.Values;
    var queryParams = ViewContext.HttpContext.Request.Query
        .Where(q => q.Key != "page")
        .ToDictionary(q => q.Key, q => q.Value.ToString());
}

@if (Model.TotalPages > 1)
{
    <nav class="sttech-pagination mt-4" aria-label="Page navigation">
        <ul class="pagination justify-content-center gap-1">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-all-route-data="@(new Dictionary<string, string>(queryParams) { ["page"] = (Model.CurrentPage - 1).ToString() })">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @for (var i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-all-route-data="@(new Dictionary<string, string>(queryParams) { ["page"] = i.ToString() })">@i</a>
                </li>
            }

            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-all-route-data="@(new Dictionary<string, string>(queryParams) { ["page"] = (Model.CurrentPage + 1).ToString() })">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
        <p class="text-center pagination-info">Page @Model.CurrentPage of @Model.TotalPages</p>
    </nav>
}