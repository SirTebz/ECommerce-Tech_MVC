@model SirTebz_Tech.Models.ViewModels.ProductDetailViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="product-detail-page py-4">
    <div class="container-xl">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb sttech-breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index">Products</a></li>
                <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.CategoryName</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>

        <div class="row g-4 g-lg-5">
            <!-- PRODUCT IMAGE -->
            <div class="col-lg-5">
                <div class="product-detail-img-wrap">
                    @if (Model.IsOnSale)
                    {
                        <div class="detail-badge-sale">-@Model.DiscountPercent% OFF</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="product-detail-img"
                             onerror="this.src='/images/placeholder.jpg'" id="mainImage" />
                    }
                    else
                    {
                        <div class="product-detail-img-placeholder">
                            <i class="bi bi-laptop"></i>
                        </div>
                    }
                </div>
            </div>

            <!-- PRODUCT INFO -->
            <div class="col-lg-7">
                <div class="product-detail-info">
                    <div class="detail-meta mb-2">
                        <span class="detail-brand">@Model.BrandName</span>
                        <span class="detail-category">@Model.CategoryName</span>
                    </div>

                    <h1 class="detail-title">@Model.Name</h1>

                    <!-- PRICE -->
                    <div class="detail-price-block">
                        <span class="detail-price">R @Model.Price.ToString("N2")</span>
                        @if (Model.IsOnSale && Model.OriginalPrice.HasValue)
                        {
                            <span class="detail-original-price">R @Model.OriginalPrice.Value.ToString("N2")</span>
                            <span class="detail-saving">Save R @((Model.OriginalPrice.Value - Model.Price).ToString("N2"))</span>
                        }
                    </div>

                    <!-- STOCK -->
                    <div class="detail-stock mt-2 mb-3">
                        @if (Model.Stock > 5)
                        {
                            <span class="stock-badge in-stock"><i class="bi bi-check-circle-fill me-1"></i>In Stock (@Model.Stock units)</span>
                        }
                        else if (Model.Stock > 0)
                        {
                            <span class="stock-badge low-stock"><i class="bi bi-exclamation-circle-fill me-1"></i>Low Stock — only @Model.Stock left!</span>
                        }
                        else
                        {
                            <span class="stock-badge out-stock"><i class="bi bi-x-circle-fill me-1"></i>Out of Stock</span>
                        }
                    </div>

                    <!-- DESCRIPTION -->
                    <p class="detail-description">@Model.Description</p>

                    <!-- QUICK SPECS -->
                    @if (Model.Specifications.Any())
                    {
                        <div class="quick-specs mb-4">
                            @foreach (var spec in Model.Specifications.Take(4))
                            {
                                <div class="quick-spec-item">
                                    <span class="spec-key">@spec.Key</span>
                                    <span class="spec-value">@spec.Value</span>
                                </div>
                            }
                        </div>
                    }

                    <!-- ACTIONS -->
                    <div class="detail-actions">
                        @if (Model.Stock > 0)
                        {
                            <div class="qty-row d-flex gap-3 align-items-center mb-3">
                                <label class="qty-label">Quantity:</label>
                                <div class="qty-control d-flex align-items-center">
                                    <button class="btn btn-qty" onclick="changeQty(-1)"><i class="bi bi-dash"></i></button>
                                    <input type="number" id="quantityInput" value="1" min="1" max="@Model.Stock" class="qty-input" />
                                    <button class="btn btn-qty" onclick="changeQty(1)"><i class="bi bi-plus"></i></button>
                                </div>
                            </div>

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <div class="d-flex gap-3 flex-wrap">
                                    <button class="btn btn-detail-cart flex-grow-1" id="addToCartBtn"
                                            onclick="addToCartWithQty(@Model.Id)">
                                        <i class="bi bi-bag-plus me-2"></i>Add to Cart
                                    </button>
                                    <button class="btn btn-detail-compare" onclick="addToCompare(@Model.Id, '@Model.Name.Replace("'","\\'")')">
                                        <i class="bi bi-bar-chart-steps me-1"></i>Compare
                                    </button>
                                </div>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login" class="btn btn-detail-cart w-100">
                                    <i class="bi bi-person me-2"></i>Login to Add to Cart
                                </a>
                            }
                        }
                        else
                        {
                            <button class="btn btn-out-of-stock w-100" disabled>Out of Stock</button>
                        }
                    </div>

                    <!-- TRUST BADGES -->
                    <div class="trust-badges d-flex gap-3 mt-4 flex-wrap">
                        <div class="trust-item"><i class="bi bi-truck"></i> Free Delivery</div>
                        <div class="trust-item"><i class="bi bi-shield-check"></i> 2yr Warranty</div>
                        <div class="trust-item"><i class="bi bi-arrow-counterclockwise"></i> 30-Day Return</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SPECIFICATIONS TABLE -->
        @if (Model.Specifications.Any())
        {
            <div class="specs-section mt-5">
                <div class="section-tabs mb-3">
                    <button class="tab-btn active" onclick="showTab('specs')">Specifications</button>
                    <button class="tab-btn" onclick="showTab('desc')">Description</button>
                </div>

                <div id="tab-specs" class="tab-content">
                    <div class="specs-table-wrap">
                        <table class="table sttech-specs-table">
                            <thead>
                                <tr><th colspan="2" class="specs-table-header">@Model.Name — Technical Specifications</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var spec in Model.Specifications.OrderBy(s => s.DisplayOrder))
                                {
                                    <tr>
                                        <td class="spec-key-cell">@spec.Key</td>
                                        <td class="spec-val-cell">@spec.Value</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="tab-desc" class="tab-content" style="display:none">
                    <div class="desc-content">
                        <p>@Model.Description</p>
                    </div>
                </div>
            </div>
        }

        <!-- RELATED PRODUCTS -->
        @if (Model.RelatedProducts.Any())
        {
            <div class="related-section mt-5">
                <h3 class="section-title mb-4">Related Products</h3>
                <div class="row g-3 g-md-4">
                    @foreach (var rel in Model.RelatedProducts)
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            @await Html.PartialAsync("_ProductCard", rel)
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
function changeQty(delta) {
    const input = document.getElementById('quantityInput');
    const max = parseInt(input.max);
    let val = parseInt(input.value) + delta;
    input.value = Math.max(1, Math.min(val, max));
}
function addToCartWithQty(productId) {
    const qty = parseInt(document.getElementById('quantityInput').value);
    const btn = document.getElementById('addToCartBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Adding...';
    fetch('/Cart/AddToCart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
        body: `productId=${productId}&quantity=${qty}&__RequestVerificationToken=${getAntiForgeryToken()}`
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            updateCartBadge(data.cartCount);
            showToast('success', '🛒 Added to cart!');
        }
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-bag-plus me-2"></i>Add to Cart';
    })
    .catch(() => { btn.disabled = false; btn.innerHTML = '<i class="bi bi-bag-plus me-2"></i>Add to Cart'; });
}
function showTab(tab) {
    document.getElementById('tab-specs').style.display = tab === 'specs' ? '' : 'none';
    document.getElementById('tab-desc').style.display = tab === 'desc' ? '' : 'none';
    document.querySelectorAll('.tab-btn').forEach((b, i) => {
        b.classList.toggle('active', (i === 0 && tab === 'specs') || (i === 1 && tab === 'desc'));
    });
}
</script>
}